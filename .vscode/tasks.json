{
    "version": "2.0.0",
    "tasks": [
        {
            // Shared label for all platforms — macOS/Linux use build-phase1.sh, Windows uses PowerShell.
            "type": "shell",
            "label": "Build Breakout (Phase I)",
            "command": "powershell.exe",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/build-phase1.ps1"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "windows": {
                "command": "powershell.exe",
                "args": [
                    "-ExecutionPolicy",
                    "Bypass",
                    "-File",
                    "${workspaceFolder}/scripts/build-phase1.ps1"
                ]
            },
            "osx": {
                "command": "bash",
                "args": [
                    "${workspaceFolder}/scripts/build-phase1.sh"
                ]
            },
            "linux": {
                "command": "bash",
                "args": [
                    "${workspaceFolder}/scripts/build-phase1.sh"
                ]
            }
        }
    ]
}
