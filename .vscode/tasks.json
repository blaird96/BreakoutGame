{
    "version": "2.0.0",
    "tasks": [
        {
            // Call the shared build script so toolchain detection lives in one place for the team.
            // That avoids committing one teammate's exact compiler and SFML paths here.
            "type": "shell",
            "label": "Build Breakout (WinLibs + SFML)",
            "command": "powershell.exe",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\build-phase1.ps1"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        }
    ]
}
