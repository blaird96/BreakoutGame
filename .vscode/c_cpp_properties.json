{
    "configurations": [
        {
            // IntelliSense needs a few likely include roots because teammates may use MSYS2 or standalone SFML.
            // BREAKOUT_SFML_ROOT remains the preferred local override when someone's install lives elsewhere.
            "name": "Win32",
            "includePath": [
                "${workspaceFolder}/**",
                "${env:BREAKOUT_SFML_ROOT}/include",
                "C:/msys64/ucrt64/include",
                "C:/SFML-3.0.2/include"
            ],
            "defines": [],
            // Prefer g++.exe from PATH so the shared repo does not hardcode one teammate's compiler folder.
            "compilerPath": "g++.exe",
            "cStandard": "c17",
            "cppStandard": "c++20",
            "intelliSenseMode": "windows-gcc-x64"
        },
        {
            "name": "Mac (Apple silicon)",
            "includePath": [
                "${workspaceFolder}/**",
                "${env:BREAKOUT_SFML_ROOT}/include",
                "/opt/homebrew/include",
                "/usr/local/include"
            ],
            "defines": [],
            "compilerPath": "/usr/bin/clang++",
            "cStandard": "c17",
            "cppStandard": "c++20",
            "intelliSenseMode": "macos-clang-arm64"
        },
        {
            "name": "Mac (Intel)",
            "includePath": [
                "${workspaceFolder}/**",
                "${env:BREAKOUT_SFML_ROOT}/include",
                "/opt/homebrew/include",
                "/usr/local/include"
            ],
            "defines": [],
            "compilerPath": "/usr/bin/clang++",
            "cStandard": "c17",
            "cppStandard": "c++20",
            "intelliSenseMode": "macos-clang-x64"
        }
    ],
    "version": 4
}
