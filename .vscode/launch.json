{
    "version": "0.2.0",
    "configurations": [
        {
            // Debugger settings live per-OS so GDB pretty-printing is not sent to LLDB.
            "name": "Breakout: Debug (Phase I)",
            "type": "cppdbg",
            "request": "launch",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "externalConsole": false,
            "program": "${workspaceFolder}/main.exe",
            "preLaunchTask": "Build Breakout (Phase I)",
            "windows": {
                "program": "${workspaceFolder}/main.exe",
                "environment": [
                    {
                        "name": "PATH",
                        "value": "${workspaceFolder}/runtime;${env:BREAKOUT_RUNTIME_BIN};${env:PATH}"
                    }
                ],
                "MIMode": "gdb",
                "miDebuggerPath": "gdb.exe",
                "setupCommands": [
                    {
                        "description": "Enable pretty-printing for gdb",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
                ]
            },
            "osx": {
                "program": "${workspaceFolder}/main",
                "environment": [
                    {
                        "name": "PATH",
                        "value": "${env:PATH}"
                    }
                ],
                "MIMode": "lldb",
                "setupCommands": []
            },
            "linux": {
                "program": "${workspaceFolder}/main",
                "environment": [
                    {
                        "name": "PATH",
                        "value": "${env:PATH}"
                    }
                ],
                "MIMode": "gdb",
                "miDebuggerPath": "gdb",
                "setupCommands": [
                    {
                        "description": "Enable pretty-printing for gdb",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
                ]
            }
        }
    ]
}
